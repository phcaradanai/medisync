# MediSync — local development environment
# Copy to .env and adjust for your machine.
# Never commit .env; real credentials must never be in version control.

# PostgreSQL connection string (pgx format).
# Local dev uses the compose-provided postgres:16-alpine.
DATABASE_URL=postgres://postgres:dev%214555%402026@122.155.164.15:5434/medisync?sslmode=disable

# NATS server URL (JetStream enabled).
# Local dev uses the compose-provided nats:2.10-alpine.
NATS_URL=nats://localhost:4222

# Connect-RPC API listen address.
HTTP_ADDR=:8080

# Structured log level: debug | info | warn | error.
LOG_LEVEL=info

# Seconds the core waits for postgres and NATS to become healthy at startup.
STARTUP_TIMEOUT_SECONDS=60

# JWT signing secret for access tokens (HMAC key, minimum 32 bytes).
# Development-only default; generate a strong random value for staging/production.
JWT_SECRET=medisync-dev-secret-change-in-production

# Access-token lifetime in seconds. Default: 3600 (1 hour).
JWT_EXPIRY_SECONDS=3600

# Bootstrap admin password. Hashed with bcrypt before storage; never logged.
# Only used on first startup when no users exist. Change after first login.
ADMIN_BOOTSTRAP_PASSWORD=medisync-local-admin-2026

# Card-token HMAC key for deterministic keyed-hash storage (minimum 32 bytes).
# Cards are never stored raw; only HMAC-SHA256(key, token) is persisted.
# Development-only default; generate a strong random value for staging/production.
CARD_TOKEN_HMAC_KEY=medisync-dev-card-hmac-change-in-prod

# Login rate limiting: maximum attempts per window per identifier and per IP.
# Set to 0 to disable rate limiting entirely.
LOGIN_RATE_LIMIT_MAX=10

# Login rate limiting: window size in seconds.
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# PrintOps service URL. The printing module posts print jobs here.
PRINT_OPS_URL=http://localhost:3000

# PrintOps API key (X-Api-Key header). Required for production.
# Leave empty for local dev with PRINT_OPS_FAKE=true.
PRINT_OPS_API_KEY=

# Set to true to use a no-op fake print_ops client (dev/testing only).
PRINT_OPS_FAKE=false

# PrintOps API key (X-Api-Key header). Required for production.
PRINT_OPS_API_KEY=printops-dev-apikey-2026

# Vending-3d-ctl-agent service URL. The fulfillment module posts
# drugDispenser commands here (Bearer auth).
VENDING_URL=http://localhost:3303

# Vending-3d-ctl-agent API Bearer token. Required for production.
VENDING_API_BEARER_TOKEN=dev-bearer-token

# Set to true to use a no-op fake vending client (dev/testing only).
FULFILLMENT_FAKE=false

# Deprecated: use FULFILLMENT_FAKE instead.
VENDING_FAKE=false
