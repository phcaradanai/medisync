# MediSync — production environment template.
# Copy to .env.production, fill in real values, and keep out of version control.
# Every placeholder MUST be replaced; the validator rejects unchanged placeholders.

# PostgreSQL connection string (pgx format).
# Use a strong, unique password set via infrastructure secret management.
# sslmode should be require or verify-full when TLS is configured.
DATABASE_URL=<postgresql-connection-string>

# NATS server URL (JetStream required).
# Use the internal Compose service name (nats://nats:4222) when running
# inside docker compose; use the external host when core runs on bare metal.
NATS_URL=<nats-url>

# Connect-RPC API listen address.
HTTP_ADDR=:8080

# Structured log level. Keep at info unless debugging production.
LOG_LEVEL=info

# Seconds the core waits for postgres and NATS to become healthy at startup.
# 120s recommended for cold-start container environments.
STARTUP_TIMEOUT_SECONDS=120

# JWT signing secret for access tokens (HMAC key, minimum 32 bytes).
# Generate a strong random secret: openssl rand -base64 64
JWT_SECRET=<jwt-signing-secret>

# Access-token lifetime in seconds. Default: 3600 (1 hour).
# Use shorter values for high-security environments (e.g., 900 = 15 min).
JWT_EXPIRY_SECONDS=3600

# Bootstrap admin password. Hashed with bcrypt before storage; never logged.
# Only used on first startup when no users exist. Use a strong unique password.
# Change after first login via the admin UI.
ADMIN_BOOTSTRAP_PASSWORD=<admin-bootstrap-password>

# Card-token HMAC key for deterministic keyed-hash storage (minimum 32 bytes).
# Cards are never stored raw; only HMAC-SHA256(key, token) is persisted.
# Generate a strong random key: openssl rand -base64 64
CARD_TOKEN_HMAC_KEY=<card-token-hmac-key>

# Login rate limiting: maximum attempts per window per identifier and per IP.
# 0 disables rate limiting. Default: 10. Production: 5–20 depending on environment.
LOGIN_RATE_LIMIT_MAX=10

# Login rate limiting: window size in seconds. Must be positive.
# Default: 60. Production: 60–300 depending on environment.
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# ── PrintOps (external printing service) ──────────────────────────────────

# PrintOps base URL. Set to the running print_ops instance.
PRINT_OPS_URL=<print-ops-url>

# PrintOps API key (X-Api-Key header). Required in production.
PRINT_OPS_API_KEY=<print-ops-api-key>

# Set to true for a no-op fake client (dev only). Never true in production.
PRINT_OPS_FAKE=false

# ── Compose-only variables (used by infra/docker-compose.prod.yml) ────

# PostgreSQL superuser credentials.
# These are separate from DATABASE_URL — the Compose file uses them
# to initialize the container; the core reads DATABASE_URL for the
# connection. They must match.
POSTGRES_USER=<db-user>
POSTGRES_PASSWORD=<db-password>
POSTGRES_DB=<db-name>
